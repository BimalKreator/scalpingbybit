# Copy to `.env` and fill in values.

# --- Paper / virtual trading (no real orders) ---
VIRTUAL_TRADING_MODE=false
VIRTUAL_BALANCE=1000.0
# Set true ONCE to delete .live_strategy_state.json, virtual_wallet.json, logs/virtual_closed_trades.json
# and reset in-memory paper trackers (fixes corrupted SL/TP in UI). Then remove or set false.
RESET_PAPER_LIVE_STATE_ON_STARTUP=false

# --- Exchange ---
EXCHANGE_ID=bybit
BYBIT_API_KEY=
BYBIT_API_SECRET=
DELTA_API_KEY=
DELTA_API_SECRET=

TRADING_SYMBOL=BTCUSDT
TRADE_AMOUNT_USD=100
LEVERAGE=5
INITIAL_CAPITAL=0.0

# Comma-separated strategy keys (see main.AVAILABLE_STRATEGIES). Empty = no auto signals.
ACTIVE_STRATEGIES=weak_momentum_reversal

# Max 1m bars kept in logs/market_data_1m.json (trim oldest when exceeded)
CANDLE_CACHE_MAX_BARS=300000
